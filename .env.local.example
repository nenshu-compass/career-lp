# ===========================
# LINE Messaging API
# ===========================

# チャネルアクセストークン（長期）
# LINE Developers > チャネル > Messaging API > チャネルアクセストークン
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# チャネルシークレット
# LINE Developers > チャネル > チャネル基本設定 > チャネルシークレット
LINE_CHANNEL_SECRET=your_channel_secret_here

# ===========================
# Supabase（将来実装）
# ===========================
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ===========================
# OpenAI API（将来実装）
# ===========================
# OPENAI_API_KEY=sk-...

# ===========================
# アプリケーション設定
# ===========================

# 本番サイトのURL（LINE通知のリンク生成に使用）
NEXT_PUBLIC_BASE_URL=https://your-domain.vercel.app

# 内部API認証キー（管理画面 → API呼び出し時に使用）
INTERNAL_API_KEY=generate_a_random_secret_here

# Cronジョブ認証（フォローアップ送信API）
CRON_SECRET=generate_another_random_secret_here
